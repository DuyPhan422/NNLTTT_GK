<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

  <persistence-unit name="productPU" transaction-type="RESOURCE_LOCAL">

    <!-- Đăng ký tất cả các Entity của project -->
    <class>com.company.ems.model.Student</class>
    <class>com.company.ems.model.Teacher</class>
    <class>com.company.ems.model.Course</class>
    <class>com.company.ems.model.Room</class>
    <class>com.company.ems.model.Class</class>
    <class>com.company.ems.model.Enrollment</class>
    <class>com.company.ems.model.Invoice</class>
    <class>com.company.ems.model.Payment</class>
    <class>com.company.ems.model.Schedule</class>
    <class>com.company.ems.model.Attendance</class>
    <class>com.company.ems.model.Staff</class>
    <class>com.company.ems.model.UserAccount</class>
    <class>com.company.ems.model.Result</class>

    <properties>
      <!-- Kết nối MySQL -->
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="jakarta.persistence.jdbc.url"
                value="jdbc:mysql://localhost:3306/mis_language_center?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=Asia/Ho_Chi_Minh"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.password" value="root"/>

      <!-- Hibernate config -->
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>

      <!--
        update: Hibernate tự tạo / cập nhật bảng theo Entity
        Dùng "create" nếu muốn xoá và tạo lại toàn bộ bảng mỗi lần chạy (chỉ dùng khi dev)
        Dùng "validate" khi đã ổn định schema trên production
      -->
      <property name="hibernate.hbm2ddl.auto" value="update"/>
    </properties>

  </persistence-unit>

</persistence>
